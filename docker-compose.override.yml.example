# Example local overrides (ports, extra mounts). Not loaded by Compose unless present.
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   edit docker-compose.override.yml
#
# docker-compose.override.yml is gitignored—do not commit secrets or machine-specific paths.
#
# Common reasons: host already uses 8000/8089; enable Claude log bind mount with your OS path.

services:
  so1:
    # Example: map Splunk Web and mgmt API to different host ports
    # ports:
    #   - "9000:8000"
    #   - "9089:8089"
    #
    # Example (macOS): ingest Claude Desktop logs into claude_logs (see docs/CONFIGURATION.md)
    # volumes:
    #   - ${HOME}/Library/Logs/Claude:/var/log/claude_logs:rw
