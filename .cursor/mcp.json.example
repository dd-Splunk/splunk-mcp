{
  "mcpServers": {
    "vellem": {
      "command": "/Applications/Vellem.app/Contents/Resources/vellem-mcp"
    },
    "splunk-mcp-server": {
      "command": "node",
      "args": ["scripts/mcp-stdio-http-bridge.mjs"],
      "env": {
        "MCP_URL": "http://localhost:8090/mcp"
      }
    }
  }
}
