{
  "mcpServers": {
    "splunk-mcp-server": {
      "args": [
        "-y",
        "mcp-remote",
        "https://localhost:8089/services/mcp",
        "--header",
        "Authorization: Bearer REPLACE_AFTER_make_update-cursor-config"
      ],
      "command": "npx",
      "env": {
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      }
    }
  }
}
