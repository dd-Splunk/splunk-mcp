# Environment files (contain secrets)
.env
# Local copy of tpl.env.example — edit op:// paths here (never commit)
tpl.env

# Entire host secrets directory (legacy: tokens, generated passwords, etc.)
.secrets/
mcp_token.txt
*.token

# Claude configuration
.claude/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Docker volumes (data stored in named volumes)
docker-compose.override.yml

# Cursor — mcp.json may contain secrets; agent prompts and S4R rule are tracked
.cursor/mcp.json
**/.cursor/rules/*
!**/.cursor/rules/s4r-buttercup-agents.mdc
!**/.cursor/agents/**

# Node dependencies for local build contexts
# Cursor / Windsurf local rules (any path in repo)
**/.windsurf/rules/

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# Temporary files
*.tmp
.*.tmp

# Internal SE materials (local only — not for public repo)
demo-slides/claude-enterprise-*

# Splunk App

**/local/
*.lic
**/metadata/local.meta

