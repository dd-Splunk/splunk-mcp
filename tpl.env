# Splunk Configuration — template only (commit safe)
# Replace every op:// path with items that exist in YOUR 1Password vault.
# See docs/INSTALLATION.md § "1Password Setup" and docs/PRESALES.md.
#
# For reproducible demos, pin SPLUNK_IMAGE to a specific tag (e.g. splunk/splunk:10.2.0)
# instead of :latest.

SPLUNK_IMAGE=splunk/splunk:latest
SPLUNK_PASSWORD=op://YourVault/YourItem/password

# Splunkbase (required): account that can download apps from splunkbase.splunk.com
SPLUNKBASE_USER=op://YourVault/Splunkbase/username
SPLUNKBASE_PASS=op://YourVault/Splunkbase/password

# Timezone for the Splunk container
TZ=Europe/Brussels
