# Copy to .env (gitignored):  cp .env.example .env
# Fill in values — never commit .env.
# Docker Compose loads .env automatically; make up requires SPLUNK_PASSWORD and Splunkbase
# credentials for SPLUNK_APPS_URL downloads.

SPLUNK_IMAGE=splunk/splunk:latest
SPLUNK_PASSWORD=

# Splunkbase (splunkbase.splunk.com) — same account you use to download apps in the browser
SPLUNKBASE_USER=
SPLUNKBASE_PASS=

TZ=Europe/Brussels

# Required: password for the non-admin MCP execution user (default splunker).
# This repo does not write passwords to disk; provide it via .env (Path B) or op run (Path A).
SPLUNK_MCP_PASSWORD=

# Optional (splunk-init / setup-splunk.sh):
# SPLUNK_REST_USER — REST login for setup script (default: admin). Deprecated: SPLUNK_USER (still read by compose).
# SPLUNK_MCP_USER — MCP user created + token minted (default: splunker).
# SPLUNK_MLTK_USER — who gets MLTK_ROLE (default: same as SPLUNK_MCP_USER; use admin for management account).
# MLTK_ROLE — Splunk role from MLTK app (default: mltk_dsdl_admin; empty to skip; mltk_admin on older MLTK).
# SPLUNK_REST_USER=admin
# SPLUNK_MCP_USER=splunker
# SPLUNK_MLTK_USER=admin
# MLTK_ROLE=mltk_admin
