# Copy to .env (gitignored):  cp .env.example .env
# Fill in values — never commit .env.
# Docker Compose loads .env automatically; make up requires SPLUNK_PASSWORD and Splunkbase
# credentials for SPLUNK_APPS_URL downloads.

SPLUNK_IMAGE=splunk/splunk:latest
SPLUNK_PASSWORD=

# Splunkbase (splunkbase.splunk.com) — same account you use to download apps in the browser
SPLUNKBASE_USER=
SPLUNKBASE_PASS=

TZ=Europe/Brussels

# Optional (splunk-init / setup-splunk.sh): MLTK role assignment for Splunk AI Toolkit.
# MLTK_ROLES_USER — which Splunk user gets the role (default: splunker). Set to admin to use the management account.
# MLTK_ROLE — role name created by MLTK (default: mltk_dsdl_admin). Use mltk_admin on older MLTK builds, or leave empty to skip.
# MLTK_ROLES_USER=admin
# MLTK_ROLE=mltk_admin
